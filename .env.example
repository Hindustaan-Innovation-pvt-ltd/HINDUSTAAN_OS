# [1] Direct Backend URL (For Production or Live Testing)
# Agar aapko seedha live server par connect karna hai, toh isko uncomment karein:
# (Note: Ye local dev aur production dono me kaam karega aur Proxy ko bypass kar dega)
# VITE_API_URL=https://api.hindustaan.in

# [2] Local Dev Proxy Target (Only used during 'npm run dev')
# Agar aapka local backend 5000 ke alawa kisi aur port par hai (e.g. 8080)
# Ya phir aap kisi specific network IP (e.g. http://192.168.1.5:3000) par local testing kar rahe hain:
VITE_PROXY_TARGET=http://localhost:5000
